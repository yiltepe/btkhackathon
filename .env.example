GEMINI_API_KEY=
SERPER_API_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: demo account sign-in button on the landing page.
# Set NEXT_PUBLIC_DEMO_ENABLED=1 to render the button.
# DEMO_USER_ID is the Clerk user.id of the demo account (server-only).
# Never set a demo password as a NEXT_PUBLIC_* var — it would leak into the client bundle.
NEXT_PUBLIC_DEMO_ENABLED=
DEMO_USER_ID=
